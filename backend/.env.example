# =============================================
# GreenRoute Backend Environment Variables
# =============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# Local: mongodb://localhost:27017/greenroute
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/greenroute
MONGODB_URI=mongodb://localhost:27017/greenroute

# Google Maps API Key
# Get yours at: https://console.cloud.google.com/
# Enable: Directions API + Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Set to "true" to use dummy data when no API key
USE_DUMMY_DATA=true
